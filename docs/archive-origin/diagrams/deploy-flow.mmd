flowchart TD
    A[Коммит в main] --> B[GitHub Actions CI]
    B --> C[npm ci]
    C --> D[npx prisma generate]
    D --> E[npm run lint]
    E --> F[npm run build]
    F --> G[gitleaks]
    G --> H[GitHub Actions Deploy]
    H --> I[rsync snapshot в /opt/madcore-gena]
    I --> J[server-db-backup.sh]
    J --> K[docker compose up -d --build postgres app nginx]
    K --> L[docker compose exec app npx prisma migrate deploy]
    L --> M[production-smoke.sh]
    M --> N[Production подтверждено в сети]
